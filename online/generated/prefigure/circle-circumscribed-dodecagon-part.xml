<?xml version="1.0"?>
<prefigure xmlns="https://prefigure.org" label="circle-circumscribed-dodecagon-part" authored-label="">
              <diagram dimensions="(200,200)" margins="5">
                <!-- Reference to containing ancestor comes from PreTeXt context     -->
                <!-- Serial number is from document-wide count of PreFigure diagrams -->
                <caption>Task 1.1.2.b (11)</caption>
                <coordinates bbox="(-0.7,-0.2,0.7,1.2)">
                  <repeat parameter="k=1..2">
                    <line p1="0,0" p2="2/sqrt(3)*(cos(k*pi/3),sin(k*pi/3))" stroke="gray" thickness="1"/>
                  </repeat>

                  <repeat parameter="k=1..1">
                    <line p1="0,0" p2="(cos(k*pi/3+pi/6),sin(k*pi/3+pi/6))" stroke="gray" thickness="1"/>
                  </repeat>
                  
                  <repeat parameter="k=2..3">
                    <line p1="0,0" p2="2*sqrt(2-sqrt(3))*(cos(k*pi/6+pi/12),sin(k*pi/6+pi/12))" stroke="gray" thickness="0.5"/>
                  </repeat>
                  

                  <circle center="(0,0)" radius="1" thickness="1" stroke="black" fill-color="none"/>
                  <polygon points="(0,0)+2/sqrt(3)*(cos(k*pi/3),sin(k*pi/3))" parameter="k=0..5" closed="yes" stroke="blue" thickness="1"/>
                  <polygon points="(0,0)+2*sqrt(2-sqrt(3))*(cos(k*pi/6+pi/12),sin(k*pi/6+pi/12))" parameter="k=0..11" closed="yes" stroke="red" thickness="2"/>
                  <definition>O=(0,0)</definition>
                  <definition>A=(cos(pi/3),sin(pi/3))</definition>
                  <definition>C=(0,1)</definition>
                  <definition>D=2/sqrt(3)*(cos(pi/3),sin(pi/3))</definition>
                  <definition>E=2*sqrt(2-sqrt(3))*(cos(5*pi/12),sin(5*pi/12))</definition>
                  <point p="O" size="2" alignment="south"> <m>O</m> </point>
                  <point p="A" size="2" alignment="south"> <m>A</m> </point>
                  <point p="C" size="2" alignment="north"> <m>C</m> </point>
                  <point p="D" size="2" alignment="north"> <m>D</m> </point>
                  <point p="E" size="2" alignment="north"> <m>E</m> </point>
                  <angle-marker points="(O,C,E)" thickness="1"/>
                    clear-background="yes"/&gt;
                  <angle-marker points="(E,A,O)" thickness="1"/>
                    clear-background="yes"/&gt;
                </coordinates>
              </diagram>
            </prefigure>
