<?xml version="1.0"?>
<prefigure xmlns="https://prefigure.org" label="4-wedges" authored-label="">
      <diagram dimensions="(600,200)" margins="5">
        <!-- Reference to containing ancestor comes from PreTeXt context     -->
        <!-- Serial number is from document-wide count of PreFigure diagrams -->
        <caption>Section 1.1 (1)</caption>
        <coordinates bbox="(-1,-1,5,1)">
          <definition>numwedges=4</definition>
          <definition>n=numwedges//2</definition>
          <definition>theta=pi/2/n</definition>
          <definition>start=1.5+sqrt(2)/2</definition>
          <repeat parameter="k=0..(n-1)">
            <line p1="cos(2*k*theta),sin(2*k*theta)" p2="-cos(2*k*theta),-sin(2*k*theta)" stroke="gray" thickness="1"/>
          </repeat>
          <circle center="(0,0)" radius="1" thickness="2" stroke="black" fill-color="none"/>
          <repeat parameter="k=0..n">
            <definition>A=(start+2*k*sin(theta),-0.5*cos(theta))</definition>
            <line p1="A" p2="A+(-sin(theta),cos(theta))" stroke="gray" thickness="1"/>
          </repeat>
          <repeat parameter="k=0..(n-1)">
            <definition>A=(start+2*k*sin(theta),-0.5*cos(theta))</definition>
            <line p1="A" p2="A+(sin(theta),cos(theta))" stroke="gray" thickness="1"/>
          </repeat>
          <repeat parameter="k=0..(n-1)">
            <definition>A=(start+2*k*sin(theta),-0.5*cos(theta))</definition>
            <definition>B=(start+sin(theta)+2*k*sin(theta),0.5*cos(theta))</definition>
            <arc center="A" radius="1" range="(pi/2-theta,pi/2+theta)" degrees="no" stroke="black" thickness="2"/>
            <arc center="B" radius="1" range="(3*pi/2-theta,3*pi/2+theta)" degrees="no" stroke="black" thickness="2"/>
          </repeat>
        </coordinates>
      </diagram>
    </prefigure>
